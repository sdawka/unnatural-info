---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import ActBadge from '../components/ActBadge.astro';
import ChapterNav from '../components/ChapterNav.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import '../styles/prose.css';

interface NavEntry {
  slug: string;
  title: string;
  chapterNumber?: number;
}

interface Props {
  chapter: CollectionEntry<'chapters'>;
  prev?: NavEntry;
  next?: NavEntry;
}

const { chapter, prev, next } = Astro.props;
const { title, subtitle, act, actTitle, chapterNumber, furtherReading } = chapter.data;
---

<BaseLayout title={title} description={chapter.data.summary}>
  <ReadingProgress act={act} />
  <SiteHeader />
  <main class={`cp cp--${act}`}>
    <div class="cp__container">
      <header class="cp__header">
        <div class="cp__meta">
          {act !== 'prologue' && act !== 'epilogue' && (
            <ActBadge act={act} actTitle={actTitle} />
          )}
          {chapterNumber ? (
            <span class="cp__num">
              <span class="cp__num-label">Ch.</span>
              <span class="cp__num-digit">{String(chapterNumber).padStart(2, '0')}</span>
            </span>
          ) : null}
        </div>

        <h1 class="cp__title">{title}</h1>
        {subtitle && <p class="cp__subtitle">{subtitle}</p>}

        <div class="cp__rule" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
      </header>

      <article class="cp__body prose">
        <slot />
      </article>

      {furtherReading && furtherReading.length > 0 && (
        <section class="fr">
          <h2 class="fr__heading">
            <span class="glyph-stack" aria-hidden="true">
              <span></span><span></span><span></span>
            </span>
            Influences &amp; Further Reading
          </h2>
          <ol class="fr__list">
            {furtherReading.map((entry) => (
              <li class="fr__item">
                <div class="fr__line">
                  <span class="fr__author">{entry.author}</span>
                  <span class="fr__sep" aria-hidden="true">—</span>
                  <em class="fr__title">{entry.title}</em>
                  <span class="fr__year">({entry.year})</span>
                </div>
                <p class="fr__note">{entry.note}</p>
              </li>
            ))}
          </ol>
        </section>
      )}

      <ChapterNav prev={prev} next={next} />
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .cp {
    padding: var(--space-12) var(--safe-right) var(--space-12) var(--safe-left);
  }

  .cp__container {
    max-width: var(--page-max);
    margin: 0 auto;
  }

  /* ——— Header ——— */
  .cp__header {
    max-width: var(--prose-width);
    margin: 0 auto var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  @media (min-width: 64rem) {
    .cp__header {
      margin-left: 0;
    }
  }

  .cp__meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .cp__num {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-variation-settings: 'wght' 420;
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cp__num-digit {
    color: var(--color-ink);
    font-size: 1.3em;
    letter-spacing: 0.05em;
  }

  .cp--volo-ergo-sum .cp__num-digit { color: var(--color-act-i); }
  .cp--initd .cp__num-digit        { color: var(--color-act-ii); }
  .cp--mmm .cp__num-digit          { color: var(--color-act-iii); }

  .cp__title {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 128, 'wght' 310, 'SOFT' 60;
    font-size: var(--text-4xl);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  @media (min-width: 48rem) {
    .cp__title {
      font-size: var(--text-5xl);
    }
  }

  .cp__subtitle {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'wght' 350, 'SOFT' 40;
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
    margin-top: var(--space-3);
    max-width: 36ch;
    text-wrap: pretty;
  }

  /* Three-bar rule */
  .cp__rule {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    margin-top: var(--space-6);
  }
  .cp__rule span {
    display: block;
    height: 2px;
    border-radius: 1px;
  }
  .cp--volo-ergo-sum .cp__rule span {
    background: var(--color-act-i);
  }
  .cp--initd .cp__rule span {
    background: var(--color-act-ii);
  }
  .cp--mmm .cp__rule span {
    background: var(--color-act-iii);
  }
  .cp--prologue .cp__rule span,
  .cp--epilogue .cp__rule span {
    background: var(--color-ink);
  }
  .cp__rule span:nth-child(1) { width: 40px; opacity: 1; }
  .cp__rule span:nth-child(2) { width: 24px; opacity: 0.6; }
  .cp__rule span:nth-child(3) { width: 12px; opacity: 0.3; }

  /* ——— Body ——— */
  .cp__body {
    margin: 0 auto;
  }

  @media (min-width: 64rem) {
    .cp__container {
      display: grid;
      grid-template-columns: 1fr minmax(0, var(--prose-width)) 1fr;
      align-items: start;
      column-gap: var(--space-8);
    }
    .cp__header {
      grid-column: 2;
      margin-left: 0;
    }
    .cp__body {
      grid-column: 2;
    }
    section.fr, nav.chapter-nav {
      grid-column: 2;
    }
  }

  /* ——— Further Reading ——— */
  .fr {
    max-width: var(--prose-width);
    margin: var(--space-20) auto 0;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-rule);
  }

  @media (min-width: 64rem) {
    .fr { margin-left: 0; }
  }

  .fr__heading {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-variation-settings: 'wght' 420;
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-8);
  }

  .fr__heading .glyph-stack {
    color: var(--color-ink-faint);
  }

  .cp--volo-ergo-sum .fr__heading .glyph-stack { color: var(--color-act-i); }
  .cp--initd .fr__heading .glyph-stack        { color: var(--color-act-ii); }
  .cp--mmm .fr__heading .glyph-stack          { color: var(--color-act-iii); }

  .fr__list {
    list-style: none;
    padding: 0;
    counter-reset: fr;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .fr__item {
    counter-increment: fr;
    position: relative;
    padding-left: 2.8em;
  }

  .fr__item::before {
    content: counter(fr, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0.2em;
    font-family: var(--font-mono);
    font-size: 0.7em;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
  }

  .fr__line {
    font-size: var(--text-base);
    color: var(--color-ink);
    line-height: 1.45;
  }

  .fr__author {
    font-variation-settings: 'opsz' 12, 'wght' 560;
  }

  .fr__sep {
    color: var(--color-ink-faint);
    margin: 0 0.3em;
  }

  .fr__title {
    font-style: italic;
    color: var(--color-ink);
  }

  .fr__year {
    color: var(--color-ink-muted);
    font-family: var(--font-mono);
    font-size: 0.85em;
    margin-left: 0.4em;
  }

  .fr__note {
    margin-top: var(--space-2);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    line-height: 1.55;
    max-width: 62ch;
  }

  /* ——— Mobile tuning ——— */
  @media (max-width: 48rem) {
    .cp {
      padding: var(--space-8) var(--safe-right) var(--space-8) var(--safe-left);
    }
    .cp__header {
      margin-bottom: var(--space-8);
    }
  }
</style>
