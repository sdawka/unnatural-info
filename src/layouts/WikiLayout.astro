---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/prose.css';

interface Props {
  entry: CollectionEntry<'wiki'>;
}

const { entry } = Astro.props;
const idSegments = entry.id.split('/');
const category = entry.data.category ?? (idSegments.length > 1 ? idSegments[0] : undefined);

function extractH1(body: string | undefined): string | null {
  if (!body) return null;
  const match = body.match(/^\s*#\s+(.+?)\s*$/m);
  return match ? match[1].trim() : null;
}

const h1 = extractH1(entry.body);
const fallback = idSegments[idSegments.length - 1]
  .split('-')
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(' ');
const title = entry.data.title ?? h1 ?? fallback;
const updated = entry.data.updated;
---

<BaseLayout title={title}>
  <SiteHeader />
  <main class="wp">
    <div class="wp__container">
      <nav class="wp__breadcrumb" aria-label="Breadcrumb">
        <a href="/wiki/" class="wp__crumb">
          <span class="wp__crumb-mark" aria-hidden="true">⌘</span>
          Wiki
        </a>
        {category && (
          <>
            <span class="wp__crumb-sep" aria-hidden="true">/</span>
            <span class="wp__crumb wp__crumb--cat">{category.charAt(0).toUpperCase() + category.slice(1)}</span>
          </>
        )}
        <span class="wp__crumb-sep" aria-hidden="true">/</span>
        <span class="wp__crumb wp__crumb--current">{title}</span>
      </nav>

      <header class="wp__header">
        <p class="wp__kicker">
          <span class="wp__kicker-glyph" aria-hidden="true">§</span>
          Compiled entry
        </p>
        <h1 class="wp__title">{title}</h1>
        {updated && (
          <p class="wp__updated">
            <span aria-hidden="true">↻</span>
            Updated {updated}
          </p>
        )}
      </header>

      <article class="prose wp__body">
        <slot />
      </article>

      <footer class="wp__footer">
        <a href="/wiki/" class="wp__back">
          <span aria-hidden="true">←</span> All entries
        </a>
      </footer>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .wp {
    padding: var(--space-10) var(--safe-right) var(--space-10) var(--safe-left);
  }

  .wp__container {
    max-width: var(--page-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, var(--prose-width));
    justify-content: start;
  }

  @media (min-width: 64rem) {
    .wp__container {
      grid-template-columns: 1fr minmax(0, var(--prose-width)) 1fr;
      justify-content: stretch;
    }
    .wp__breadcrumb, .wp__header, .wp__body, .wp__footer {
      grid-column: 2;
    }
  }

  /* Breadcrumb */
  .wp__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-8);
  }

  .wp__crumb {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-wiki);
    text-decoration: none;
    transition: color var(--dur-fast);
  }

  .wp__crumb:hover { color: var(--color-ink); }

  .wp__crumb-mark {
    font-size: 1.1em;
    line-height: 1;
  }

  .wp__crumb--cat {
    color: var(--color-ink-muted);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.02em;
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 12, 'wght' 400, 'SOFT' 40;
    font-size: 0.85rem;
  }

  .wp__crumb--current {
    color: var(--color-ink);
    text-transform: none;
    letter-spacing: 0.02em;
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 14, 'wght' 460, 'SOFT' 40;
    font-size: 0.85rem;
  }

  .wp__crumb-sep { color: var(--color-ink-faint); }

  /* Header */
  .wp__header {
    margin-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-bottom: var(--space-6);
    border-bottom: 1px dashed var(--color-rule);
  }

  .wp__kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-wiki);
  }

  .wp__kicker-glyph {
    font-size: 1.2em;
    line-height: 1;
    color: var(--color-wiki-soft);
  }

  .wp__title {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 96, 'wght' 340, 'SOFT' 40;
    font-size: var(--text-3xl);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  @media (min-width: 48rem) {
    .wp__title { font-size: var(--text-4xl); }
  }

  .wp__updated {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: var(--space-2);
  }

  .wp__body {
    max-width: var(--prose-width);
  }

  /* Wiki-specific prose accent */
  .wp__body :global(h1) { display: none; } /* markdown h1 is redundant with wp__title */
  .wp__body :global(blockquote) {
    border-left-color: var(--color-wiki-soft);
  }
  .wp__body :global(a) {
    border-bottom-color: color-mix(in srgb, var(--color-wiki) 50%, transparent);
  }
  .wp__body :global(a:hover) {
    color: var(--color-wiki);
  }
  .wp__body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-5) 0;
    font-size: var(--text-sm);
  }
  .wp__body :global(th),
  .wp__body :global(td) {
    border-bottom: 1px solid var(--color-rule-soft);
    text-align: left;
    padding: var(--space-2) var(--space-3);
    vertical-align: top;
  }
  .wp__body :global(th) {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-muted);
    border-bottom: 1px solid var(--color-rule);
    font-weight: 400;
  }

  .wp__footer {
    margin-top: var(--space-16);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-rule);
  }

  .wp__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-wiki);
    text-decoration: none;
    transition: transform var(--dur-med) var(--ease-out), color var(--dur-fast);
  }

  .wp__back:hover {
    color: var(--color-ink);
    transform: translateX(-3px);
  }
</style>
