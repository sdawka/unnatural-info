---
import type { CollectionEntry } from 'astro:content';

interface Props {
  chapters: CollectionEntry<'chapters'>[];
}

const { chapters } = Astro.props;

const sorted = [...chapters].sort((a, b) => a.data.order - b.data.order);

const GROUPS = [
  { key: 'prologue',       label: 'Prologue',             roman: '',    color: 'var(--color-ink-muted)', cls: 'prologue' },
  { key: 'volo-ergo-sum',  label: 'Volo Ergo Sum',        roman: 'I',   color: 'var(--color-act-i)',      cls: 'i' },
  { key: 'initd',          label: 'InitD',                roman: 'II',  color: 'var(--color-act-ii)',     cls: 'ii' },
  { key: 'mmm',            label: 'MMM',                  roman: 'III', color: 'var(--color-act-iii)',    cls: 'iii' },
  { key: 'epilogue',       label: 'Epilogue',             roman: '',    color: 'var(--color-ink-muted)', cls: 'epilogue' },
] as const;
---

<nav class="toc" aria-label="Table of contents">
  {GROUPS.map(({ key, label, roman, cls }) => {
    const group = sorted.filter((c) => c.data.act === key);
    if (group.length === 0) return null;
    const hasRoman = Boolean(roman);
    return (
      <details class={`toc__group toc__group--${cls}`} open>
        <summary class="toc__summary">
          <div class="toc__summary-left">
            {hasRoman && (
              <span class="toc__roman" aria-hidden="true">{roman}</span>
            )}
            <span class="toc__group-label">{label}</span>
            <span class="toc__count" aria-hidden="true">{String(group.length).padStart(2, '0')}</span>
          </div>
          <span class="toc__summary-chev" aria-hidden="true">↓</span>
        </summary>
        <ol class="toc__list">
          {group.map((chapter) => (
            <li class="toc__item">
              <a href={`/chapters/${chapter.id}`} class="toc__link">
                {chapter.data.chapterNumber != null ? (
                  <span class="toc__num">{String(chapter.data.chapterNumber).padStart(2, '0')}</span>
                ) : (
                  <span class="toc__num toc__num--placeholder" aria-hidden="true">·</span>
                )}
                <span class="toc__title">{chapter.data.title}</span>
                {chapter.data.subtitle && (
                  <span class="toc__subtitle">{chapter.data.subtitle}</span>
                )}
              </a>
            </li>
          ))}
        </ol>
      </details>
    );
  })}
</nav>

<style>
  .toc {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .toc__group {
    --toc-color: var(--color-ink);
  }

  .toc__group--i        { --toc-color: var(--color-act-i); }
  .toc__group--ii       { --toc-color: var(--color-act-ii); }
  .toc__group--iii      { --toc-color: var(--color-act-iii); }
  .toc__group--prologue,
  .toc__group--epilogue { --toc-color: var(--color-ink-muted); }

  .toc__summary {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    cursor: pointer;
    list-style: none;
    border-bottom: 1px solid var(--color-rule);
    transition: border-color var(--dur-fast);
  }

  .toc__summary::-webkit-details-marker { display: none; }

  .toc__summary:hover { border-bottom-color: var(--color-ink); }

  .toc__summary-left {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
  }

  .toc__roman {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-variation-settings: 'wght' 560;
    letter-spacing: 0.1em;
    color: var(--toc-color);
    border: 1px solid currentColor;
    padding: 0.15em 0.45em;
    min-width: 2.4em;
    text-align: center;
    line-height: 1;
  }

  .toc__group-label {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 30, 'wght' 380, 'SOFT' 40;
    font-size: var(--text-xl);
    color: var(--toc-color);
    letter-spacing: -0.005em;
  }

  .toc__count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
  }

  .toc__summary-chev {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    transition: transform var(--dur-med) var(--ease-out);
  }

  .toc__group[open] .toc__summary-chev {
    transform: rotate(180deg);
  }

  .toc__list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-2);
  }

  .toc__item {
    border-bottom: 1px solid var(--color-rule-soft);
  }

  .toc__item:last-child { border-bottom: none; }

  .toc__link {
    display: grid;
    grid-template-columns: 3ch 1fr;
    grid-template-rows: auto auto;
    column-gap: var(--space-4);
    row-gap: 0.15rem;
    padding: var(--space-3) 0;
    text-decoration: none;
    align-items: baseline;
    transition: padding-left var(--dur-med) var(--ease-out);
  }

  .toc__link:hover {
    padding-left: var(--space-3);
  }

  .toc__link:hover .toc__title {
    color: var(--toc-color);
  }

  .toc__num {
    grid-row: 1 / 3;
    align-self: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-muted);
    letter-spacing: 0.08em;
  }

  .toc__num--placeholder {
    color: var(--color-ink-faint);
    text-align: center;
  }

  .toc__title {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 24, 'wght' 370, 'SOFT' 30;
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-ink);
    line-height: 1.25;
    transition: color var(--dur-fast);
  }

  .toc__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }

  @media (max-width: 44rem) {
    .toc__link {
      grid-template-columns: 3ch 1fr;
      padding: var(--space-4) 0;
    }
    .toc__link:hover {
      padding-left: var(--space-2);
    }
    .toc__title {
      font-size: var(--text-base);
    }
  }
</style>
