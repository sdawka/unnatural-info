---
import type { CollectionEntry } from 'astro:content';

interface Props {
  chapters: CollectionEntry<'chapters'>[];
}

const { chapters } = Astro.props;

const sorted = [...chapters].sort((a, b) => a.data.order - b.data.order);

const GROUPS = [
  { key: 'prologue', label: 'Prologue', color: 'var(--color-ink-muted)' },
  { key: 'volo-ergo-sum', label: 'Act I — Volo Ergo Sum', color: 'var(--color-act-i)' },
  { key: 'initd', label: 'Act II — InitD', color: 'var(--color-act-ii)' },
  { key: 'mmm', label: 'Act III — MMM', color: 'var(--color-act-iii)' },
  { key: 'epilogue', label: 'Epilogue', color: 'var(--color-ink-muted)' },
] as const;
---

<nav class="toc" aria-label="Table of contents">
  {GROUPS.map(({ key, label, color }) => {
    const group = sorted.filter((c) => c.data.act === key);
    if (group.length === 0) return null;
    return (
      <div class="toc__group">
        <h3 class="toc__group-label" style={`color: ${color}`}>{label}</h3>
        <ol class="toc__list">
          {group.map((chapter) => (
            <li class="toc__item">
              <a href={`/chapters/${chapter.id}`} class="toc__link">
                {chapter.data.chapterNumber && (
                  <span class="toc__num">{String(chapter.data.chapterNumber).padStart(2, '0')}</span>
                )}
                <span class="toc__title">{chapter.data.title}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    );
  })}
</nav>

<style>
  .toc {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .toc__group-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
    font-weight: 400;
  }

  .toc__list {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-rule);
  }

  .toc__item {
    border-bottom: 1px solid var(--color-rule);
  }

  .toc__link {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-3) 0;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .toc__link:hover {
    opacity: 0.65;
  }

  .toc__num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    flex-shrink: 0;
    width: 2.5ch;
  }

  .toc__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-ink);
    line-height: 1.3;
  }
</style>
