---
interface Props {
  number: number;
}

const { number } = Astro.props;
---

<span class="sidenote-anchor" id={`sn-anchor-${number}`}>
  <sup class="sidenote-marker" aria-describedby={`sn-${number}`}>{number}</sup>
  <span class="sidenote" id={`sn-${number}`} role="note">
    <span class="sidenote__number" aria-hidden="true">{number}</span>
    <slot />
  </span>
</span>

<style>
  .sidenote-anchor {
    position: relative;
  }

  .sidenote-marker {
    font-family: var(--font-mono);
    font-size: 0.6em;
    vertical-align: super;
    line-height: 0;
    cursor: default;
    color: var(--color-ink-muted);
    margin-left: 0.1em;
  }

  .sidenote {
    /* Desktop: positioned in the right margin */
    position: absolute;
    left: calc(var(--prose-width) + var(--sidenote-gap));
    top: 0;
    width: var(--sidenote-width);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  .sidenote__number {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-style: normal;
    color: var(--color-ink-muted);
    margin-right: var(--space-2);
    vertical-align: super;
    line-height: 0;
  }

  /* Mobile: inline block below the paragraph context */
  @media (max-width: 1100px) {
    .sidenote {
      position: static;
      display: block;
      width: auto;
      margin: var(--space-4) 0 var(--space-4) var(--space-6);
      padding-left: var(--space-4);
      border-left: 2px solid var(--color-rule);
    }
  }
</style>
