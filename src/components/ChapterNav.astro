---
interface NavEntry {
  slug: string;
  title: string;
  chapterNumber?: number;
}

interface Props {
  prev?: NavEntry;
  next?: NavEntry;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="cn" aria-label="Chapter navigation">
    <div class="cn__grid">
      {prev ? (
        <a href={`/chapters/${prev.slug}`} class="cn__link cn__link--prev">
          <span class="cn__arrow" aria-hidden="true">←</span>
          <span class="cn__meta">
            {prev.chapterNumber != null && (
              <span class="cn__num">{String(prev.chapterNumber).padStart(2, '0')}</span>
            )}
            <span class="cn__label">Previous</span>
          </span>
          <span class="cn__title">{prev.title}</span>
        </a>
      ) : <span class="cn__empty" aria-hidden="true"></span>}

      {next ? (
        <a href={`/chapters/${next.slug}`} class="cn__link cn__link--next">
          <span class="cn__arrow" aria-hidden="true">→</span>
          <span class="cn__meta">
            {next.chapterNumber != null && (
              <span class="cn__num">{String(next.chapterNumber).padStart(2, '0')}</span>
            )}
            <span class="cn__label">Next</span>
          </span>
          <span class="cn__title">{next.title}</span>
        </a>
      ) : <span class="cn__empty" aria-hidden="true"></span>}
    </div>
  </nav>
)}

<style>
  .cn {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-rule);
  }

  .cn__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .cn__link {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: var(--space-3);
    row-gap: var(--space-2);
    padding: var(--space-5);
    border: 1px solid var(--color-rule);
    text-decoration: none;
    min-height: 96px;
    transition:
      border-color var(--dur-med) var(--ease-out),
      background-color var(--dur-med) var(--ease-out),
      transform var(--dur-med) var(--ease-out);
    background: transparent;
    position: relative;
  }

  .cn__link:hover {
    border-color: var(--color-ink);
    background-color: color-mix(in srgb, var(--color-ground-tint) 70%, transparent);
  }

  .cn__link:active {
    transform: translateY(1px);
  }

  .cn__link--next {
    grid-template-columns: 1fr auto;
    text-align: right;
  }

  .cn__link--next .cn__arrow {
    order: 2;
    grid-row: 1;
    grid-column: 2;
  }
  .cn__link--next .cn__meta {
    grid-row: 1;
    grid-column: 1;
    justify-self: end;
  }
  .cn__link--next .cn__title {
    grid-row: 2;
    grid-column: 1 / -1;
    justify-self: end;
  }

  .cn__arrow {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 24, 'wght' 400, 'SOFT' 40;
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--color-ink-muted);
    grid-row: 1;
    grid-column: 1;
    align-self: center;
    transition: transform var(--dur-med) var(--ease-out), color var(--dur-fast);
  }

  .cn__link:hover .cn__arrow {
    color: var(--color-ink);
  }
  .cn__link--prev:hover .cn__arrow { transform: translateX(-3px); }
  .cn__link--next:hover .cn__arrow { transform: translateX(3px); }

  .cn__meta {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    grid-row: 1;
    grid-column: 2;
    align-self: center;
  }

  .cn__num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
  }

  .cn__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
  }

  .cn__title {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 24, 'wght' 380, 'SOFT' 30;
    font-size: var(--text-lg);
    line-height: 1.25;
    color: var(--color-ink);
    grid-row: 2;
    grid-column: 2;
    text-wrap: balance;
  }

  .cn__empty {
    display: block;
  }

  /* Mobile: stack vertically, larger hit targets */
  @media (max-width: 44rem) {
    .cn__grid {
      grid-template-columns: 1fr;
    }
    .cn__link {
      min-height: 72px;
      padding: var(--space-4);
    }
    .cn__link--next {
      text-align: right;
    }
  }
</style>
