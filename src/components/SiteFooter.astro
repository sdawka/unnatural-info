---
const year = new Date().getFullYear();
---
<footer class="sf">
  <div class="sf__inner">
    <div class="sf__glyph" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <div class="sf__body">
      <p class="sf__title">UNNATURAL</p>
      <p class="sf__tagline">
        An unscientific empirical theory of everything.
      </p>
      <p class="sf__thesis">
        <span>Will creates direction.</span>
        <span>Direction creates difference.</span>
        <span>Difference creates the question.</span>
      </p>
    </div>
    <nav class="sf__meta" aria-label="Footer">
      <a href="/">Home</a>
      <a href="/wiki/">Wiki</a>
      <a href="/reading">Reading</a>
      <a href="/about">About</a>
    </nav>
  </div>

  <div class="sf__rule" aria-hidden="true"></div>

  <div class="sf__legal">
    <p class="sf__copyright">
      <span class="sf__copy-mark" aria-hidden="true">©</span>
      {year} <a href="https://sahil.pro" rel="noopener" class="sf__author">Sahil Dawka</a>. A living document.
    </p>
    <p class="sf__version">
      <span aria-hidden="true">v.</span>
      <span>working draft</span>
    </p>
  </div>
</footer>

<style>
  .sf {
    margin-top: var(--space-24);
    padding: var(--space-16) var(--safe-right) calc(var(--space-8) + var(--safe-bottom)) var(--safe-left);
    border-top: 1px solid var(--color-rule);
    background:
      linear-gradient(to bottom, transparent, color-mix(in srgb, var(--color-ground-tint) 60%, transparent));
  }

  .sf__inner {
    max-width: var(--page-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-8);
    align-items: start;
  }

  .sf__glyph {
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    padding-top: 0.5em;
  }
  .sf__glyph span {
    display: block;
    height: 2px;
    border-radius: 1px;
    background: var(--color-ink);
  }
  .sf__glyph span:nth-child(1) { width: 32px; opacity: 1; }
  .sf__glyph span:nth-child(2) { width: 20px; opacity: 0.5; }
  .sf__glyph span:nth-child(3) { width: 10px; opacity: 0.22; }

  .sf__body {
    max-width: 40ch;
  }

  .sf__title {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 20, 'wght' 600, 'SOFT' 20;
    font-size: var(--text-lg);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .sf__tagline {
    margin-top: var(--space-2);
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 24, 'wght' 360, 'SOFT' 40;
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-ink-muted);
  }

  .sf__thesis {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 0.1em;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink-faint);
    letter-spacing: 0.02em;
  }

  .sf__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    padding-top: 0.8em;
  }

  .sf__meta a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur-fast), color var(--dur-fast);
    padding-bottom: 2px;
  }

  .sf__meta a:hover {
    color: var(--color-ink);
    border-bottom-color: var(--color-ink);
  }

  .sf__rule {
    max-width: var(--page-max);
    margin: var(--space-10) auto var(--space-6);
    height: 1px;
    background: var(--color-rule-soft);
  }

  .sf__legal {
    max-width: var(--page-max);
    margin: 0 auto;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
  }

  .sf__copyright {
    color: var(--color-ink-muted);
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .sf__copy-mark {
    font-family: var(--font-display);
    font-size: 1.1em;
    color: var(--color-ink-faint);
    margin-right: 0.1em;
  }

  .sf__author {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    transition: border-color var(--dur-fast);
    padding-bottom: 1px;
  }

  .sf__author:hover {
    border-bottom-color: var(--color-ink);
  }

  .sf__version {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink-faint);
  }

  @media (max-width: 44rem) {
    .sf {
      padding-top: var(--space-12);
      margin-top: var(--space-16);
    }
    .sf__inner {
      grid-template-columns: auto 1fr;
      row-gap: var(--space-6);
    }
    .sf__meta {
      grid-column: 1 / -1;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: flex-start;
      gap: var(--space-5);
      padding-top: 0;
    }
    .sf__rule {
      margin: var(--space-6) auto var(--space-4);
    }
    .sf__legal {
      flex-direction: column;
      gap: var(--space-2);
      align-items: flex-start;
    }
  }
</style>
