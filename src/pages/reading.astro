---

<BaseLayout
  title="Further Reading"
  description="The source graph behind UNNATURAL — a reading list organized by act, theme, and tradition."
>
  <SiteHeader />
  <main class="reading-page">
    <div class="reading-page__container">

      <header class="reading-header">
        <p class="reading-header__label">Source graph</p>
        <h1 class="reading-header__title">Further Reading</h1>
        <p class="reading-header__intro">
          Treat this as a graph, not a canon. Some items are bedrock. Some are
          bridge-builders. Some are deliberately wild but useful. The point is
          breadth with spine.
        </p>
      </header>

      <section class="shelf-section">
        <h2 class="shelf-section__heading">A first shelf</h2>
        <p class="shelf-section__note">
          If you needed to compress the whole map into a starting point.
        </p>
        <ol class="shelf-list">
          {firstShelf.map((item, i) => (
            <li class="shelf-list__item">
              <span class="shelf-list__num">{String(i + 1).padStart(2, '0')}</span>
              <span class="shelf-list__author">{item.author}</span>
              <em class="shelf-list__title">{item.title}</em>
              <span class="shelf-list__year">{item.year}</span>
            </li>
          ))}
        </ol>
      </section>

      <div class="reading-sections">
        {sections.map((section) => (
          <section class="reading-section" id={section.id}>
            <h2 class="reading-section__heading">{section.label}</h2>
            {section.note && (
              <p class="reading-section__note">{section.note}</p>
            )}
            {'items' in section && section.items && (
              <ul class="reading-list">
                {section.items.map((item) => (
                  <li class="reading-list__item">{item}</li>
                ))}
              </ul>
            )}
            {'subsections' in section && section.subsections && (
              <div class="reading-subsections">
                {section.subsections.map((sub) => (
                  <div class="reading-subsection">
                    <h3 class="reading-subsection__heading">{sub.label}</h3>
                    <ul class="reading-list">
                      {sub.items.map((item) => (
                        <li class="reading-list__item">{item}</li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            )}
          </section>
        ))}
      </div>

    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .reading-page {
    padding: var(--space-12) var(--space-6);
  }

  .reading-page__container {
    max-width: var(--page-max);
    margin: 0 auto;
  }

  /* Header */
  .reading-header {
    max-width: var(--prose-width);
    margin-bottom: var(--space-16);
  }

  .reading-header__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-3);
  }

  .reading-header__title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 300;
    color: var(--color-ink);
    margin-bottom: var(--space-4);
  }

  .reading-header__intro {
    font-size: var(--text-base);
    color: var(--color-ink-muted);
    line-height: 1.7;
  }

  /* First shelf */
  .shelf-section {
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .shelf-section__heading {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-2);
  }

  .shelf-section__note {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin-bottom: var(--space-6);
    font-style: italic;
  }

  .shelf-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(26rem, 1fr));
    gap: var(--space-3) var(--space-8);
  }

  .shelf-list__item {
    display: grid;
    grid-template-columns: 2rem 1fr;
    grid-template-rows: auto auto;
    column-gap: var(--space-3);
    align-items: baseline;
  }

  .shelf-list__num {
    grid-row: 1 / 3;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    padding-top: 0.2em;
  }

  .shelf-list__author {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-ink);
  }

  .shelf-list__title {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    display: block;
  }

  .shelf-list__year {
    display: none;
  }

  /* Reading sections */
  .reading-sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .reading-section {
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .reading-section:last-child {
    border-bottom: none;
  }

  .reading-section__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 300;
    font-style: italic;
    color: var(--color-ink);
    margin-bottom: var(--space-3);
  }

  .reading-section__note {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    max-width: var(--prose-width);
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .reading-subsections {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
    gap: var(--space-8);
  }

  .reading-subsection__heading {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-3);
  }

  .reading-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .reading-list__item {
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-ink);
    padding-left: var(--space-4);
    position: relative;
  }

  .reading-list__item::before {
    content: "–";
    position: absolute;
    left: 0;
