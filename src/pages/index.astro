---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import TableOfContents from '../components/TableOfContents.astro';

const chapters = await getCollection('chapters', ({ data }) => !data.draft);
---

<BaseLayout title="UNNATURAL">
  <SiteHeader />

  <main class="home">

    <!-- Hero -->
    <section class="hero">
      <div class="hero__inner">
        <p class="hero__eyebrow">
          <span class="hero__eyebrow-stack" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
          <span>An <em>unscientific<a href="#unscientific-note" class="hero__footnote-mark" aria-label="What unscientific means">*</a></em> empirical theory of everything</span>
        </p>

        <div class="hero__question" aria-labelledby="hero-q">
          <p class="hero__question-label">A child asks it first.</p>
          <p class="hero__question-text" id="hero-q">
            <span class="hero__quote" aria-hidden="true">“</span>What are we<span class="hero__qmark">?</span><span class="hero__quote" aria-hidden="true">”</span>
          </p>
          <p class="hero__wonder">Thirty years of wondering.</p>
        </div>

        <p class="hero__answer-lead">
          One word eventually fits.
        </p>

        <h1 class="hero__title" aria-label="UNNATURAL">
          <span class="hero__title-letter" data-delay="0">U</span><span class="hero__title-letter" data-delay="1">N</span><span class="hero__title-letter" data-delay="2">N</span><span class="hero__title-letter" data-delay="3">A</span><span class="hero__title-letter" data-delay="4">T</span><span class="hero__title-letter" data-delay="5">U</span><span class="hero__title-letter" data-delay="6">R</span><span class="hero__title-letter" data-delay="7">A</span><span class="hero__title-letter" data-delay="8">L</span>
        </h1>

        <p class="hero__subtitle">
          Natural beings who slipped into the <a href="/chapters/10-the-information-physical-duality" class="hero__subtitle-link">information realm</a>. Now we loop it back through the physical world that made us.
        </p>

        <div class="thesis">
          <ol class="thesis__lines">
            <li><span class="thesis__accent thesis__accent--i">Want</span> creates direction.</li>
            <li>Direction creates <span class="thesis__accent thesis__accent--ii">difference</span>.</li>
            <li>Difference creates self, world, value, and distinction.</li>
            <li>Distinction creates <em>models</em>.</li>
            <li>Models guide <span class="thesis__accent thesis__accent--iii">manifestation</span>.</li>
            <li>The loop recurses. Life learns, grows, and complexifies.</li>
          </ol>
        </div>

        <aside class="hero__disclaimer" id="unscientific-note">
          <span class="hero__disclaimer-marker" aria-hidden="true">*</span>
          <p>
            "Unscientific" does not mean anti-science.
            It means: not reducible to one formal discipline,
            not claiming lab-grade proof at every layer,
            willing to begin from lived experience,
            but still committed to reality, clarity, and honest uncertainty.
          </p>
        </aside>

        <p class="hero__status" aria-label="Document status">
          <span class="hero__status-dot" aria-hidden="true"></span>
          <span class="hero__status-label">Living document</span>
          <span class="hero__status-sep" aria-hidden="true">·</span>
          <span class="hero__status-note">a work in progress, continuously refined.</span>
        </p>
      </div>
    </section>

    <!-- Three Acts — asymmetric index -->
    <section class="acts" aria-labelledby="acts-heading">
      <div class="acts__inner">
        <header class="acts__header">
          <p class="acts__label">
            <span class="glyph-stack" aria-hidden="true">
              <span></span><span></span><span></span>
            </span>
            Three Acts
          </p>
          <h2 class="acts__heading" id="acts-heading">
            The argument<br />in three movements.
          </h2>
        </header>

        <ol class="acts__grid">
          <li class="act-card act-card--i">
            <a href="/acts/volo-ergo-sum" class="act-card__link">
              <div class="act-card__numeral" aria-hidden="true">I</div>
              <div class="act-card__body">
                <div class="act-card__title-row">
                  <h3 class="act-card__name">Volo Ergo Sum</h3>
                  <span class="act-card__arrow" aria-hidden="true">→</span>
                </div>
                <p class="act-card__premise">Why anything happens at all.</p>
                <p class="act-card__detail">Before thought, there were feelings. The layer we share with the animals. Before feelings, there was want: a bacterium leaning along a chemical gradient, the floor of the whole stack.</p>
              </div>
            </a>
          </li>

          <li class="act-card act-card--ii">
            <a href="/acts/initd" class="act-card__link">
              <div class="act-card__numeral" aria-hidden="true">II</div>
              <div class="act-card__body">
                <div class="act-card__title-row">
                  <h3 class="act-card__name">init.d</h3>
                  <span class="act-card__arrow" aria-hidden="true">→</span>
                </div>
                <p class="act-card__premise">What appears once distinction begins.</p>
                <p class="act-card__detail">Finite beings cannot meet reality whole. The universe is fractal and chaotic: infinite detail at every scale, bottomless in both directions. Distinction is how we boot up inside that excess.</p>
              </div>
            </a>
          </li>

          <li class="act-card act-card--iii">
            <a href="/acts/mmm" class="act-card__link">
              <div class="act-card__numeral" aria-hidden="true">III</div>
              <div class="act-card__body">
                <div class="act-card__title-row">
                  <h3 class="act-card__name">MMM</h3>
                  <span class="act-card__arrow" aria-hidden="true">→</span>
                </div>
                <p class="act-card__premise">How life grows through recursive world-contact.</p>
                <p class="act-card__detail">Measure, Model, Manifest. The most meta process we can observe, running in a cell, a child, a civilisation. Dupoux, LeCun &amp; Malik (2026) arrive at a structural echo (observation, active behavior, meta-control) from a different direction.</p>
              </div>
            </a>
          </li>
        </ol>
      </div>
    </section>

    <!-- Table of Contents -->
    <section class="toc-section">
      <div class="toc-section__inner">
        <header class="toc-section__header">
          <p class="toc-section__label">Contents</p>
          <p class="toc-section__hint">
            <span aria-hidden="true">↓</span> Twenty-one chapters across three acts
          </p>
        </header>
        <TableOfContents chapters={chapters} />
      </div>
    </section>

  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .home {
    padding-top: 0;
  }

  /* ——— Hero ——— */
  .hero {
    padding: var(--space-20) var(--safe-right) var(--space-16) var(--safe-left);
    border-bottom: 1px solid var(--color-rule-soft);
    position: relative;
    overflow: hidden;
  }

  /* Subtle paper vignette — neutral, almost imperceptible */
  .hero::after {
    content: '';
    position: absolute;
    right: -14rem;
    bottom: -10rem;
    width: 44rem;
    height: 44rem;
    border-radius: 50%;
    background: radial-gradient(circle at center,
      color-mix(in srgb, var(--color-ink) 4%, transparent),
      transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .hero__inner {
    max-width: var(--page-max);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-6);
  }

  .hero__eyebrow em {
    font-style: italic;
    color: var(--color-ink);
  }

  .hero__eyebrow-stack {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero__eyebrow-stack span {
    display: block;
    height: 1px;
    border-radius: 1px;
    background: var(--color-ink);
  }

  .hero__eyebrow-stack span:nth-child(1) { width: 18px; opacity: 1; }
  .hero__eyebrow-stack span:nth-child(2) { width: 12px; opacity: 0.5; }
  .hero__eyebrow-stack span:nth-child(3) { width: 6px;  opacity: 0.22; }

  .hero__footnote-mark {
    color: var(--color-ink-faint);
    text-decoration: none;
    font-size: 0.7em;
    vertical-align: super;
    margin-left: 1px;
  }

  .hero__footnote-mark:hover {
    color: var(--color-ink);
  }

  /* The anchoring question */
  .hero__question {
    margin: var(--space-4) 0 var(--space-8);
    max-width: 32ch;
  }

  .hero__question-label {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 18, 'wght' 380, 'SOFT' 40;
    font-style: italic;
    font-size: var(--text-base);
    color: var(--color-ink-muted);
    margin-bottom: var(--space-3);
    line-height: 1.35;
  }

  .hero__question-text {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 144, 'wght' 300, 'SOFT' 80;
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1;
    color: var(--color-ink);
    letter-spacing: -0.025em;
    position: relative;
    display: inline-flex;
    align-items: baseline;
    gap: 0.05em;
    text-wrap: balance;
  }

  .hero__quote {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 144, 'wght' 340, 'SOFT' 100;
    color: var(--color-ink-faint);
    line-height: 1;
  }

  .hero__qmark {
    color: var(--color-ink);
    font-variation-settings: 'opsz' 144, 'wght' 360, 'SOFT' 40;
  }

  .hero__wonder {
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-ink-muted);
    position: relative;
    display: inline-block;
    padding-left: 2.5em;
  }

  .hero__wonder::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 2em;
    height: 1px;
    background: var(--color-ink-faint);
  }

  .hero__answer-lead {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-4);
    position: relative;
    display: inline-block;
    padding-left: 2.5em;
  }

  .hero__answer-lead::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 2em;
    height: 1px;
    background: var(--color-ink-faint);
  }

  .hero__subtitle-link {
    color: var(--color-act-ii);
    text-decoration: none;
    background-image: linear-gradient(to right, currentColor, currentColor);
    background-size: 100% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    padding-bottom: 1px;
    transition: color var(--dur-fast);
  }

  .hero__subtitle-link:hover {
    color: var(--color-ink);
  }

  /* Title — letter-by-letter stagger on load, stays on one line at any viewport */
  .hero__title {
    font-family: var(--font-display);
    /* Size scales with viewport but is capped so the 9 letters always fit on
       a single line within the container. 11vw at a 62rem viewport (~992px)
       gives 109px/letter × ~0.85 advance = ~835px, safely inside the
       container's content width. Desktop cap is 6rem (96px). */
    font-size: clamp(3.5rem, 11vw, 6rem);
    line-height: 0.9;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin-bottom: var(--space-6);
    display: inline-flex;
    flex-wrap: nowrap;
    max-width: 100%;
  }

  .hero__title-letter {
    display: inline-block;
    color: inherit;
    font-variation-settings: 'opsz' 144, 'wght' 320, 'SOFT' 80;
    animation: hero-letter-enter var(--dur-slow) var(--ease-out) both;
    animation-delay: calc(var(--d, 0) * 40ms);
    transition: font-variation-settings var(--dur-med) var(--ease-out);
  }

  .hero__title-letter:nth-child(1) { --d: 0; }
  .hero__title-letter:nth-child(2) { --d: 1; }
  .hero__title-letter:nth-child(3) { --d: 2; }
  .hero__title-letter:nth-child(4) { --d: 3; }
  .hero__title-letter:nth-child(5) { --d: 4; }
  .hero__title-letter:nth-child(6) { --d: 5; }
  .hero__title-letter:nth-child(7) { --d: 6; }
  .hero__title-letter:nth-child(8) { --d: 7; }
  .hero__title-letter:nth-child(9) { --d: 8; }

  .hero__title:hover .hero__title-letter {
    font-variation-settings: 'opsz' 144, 'wght' 480, 'SOFT' 0;
  }

  @keyframes hero-letter-enter {
    from {
      opacity: 0;
      transform: translateY(0.12em);
      font-variation-settings: 'opsz' 144, 'wght' 220, 'SOFT' 80;
    }
    to {
      opacity: 1;
      transform: translateY(0);
      font-variation-settings: 'opsz' 144, 'wght' 320, 'SOFT' 80;
    }
  }

  .hero__subtitle {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'wght' 350, 'SOFT' 40;
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-ink-muted);
    max-width: 36ch;
    margin-bottom: var(--space-10);
    line-height: 1.35;
    text-wrap: balance;
  }

  /* Thesis — numbered lines, accented typography */
  .thesis {
    margin-top: var(--space-10);
    margin-bottom: var(--space-10);
    max-width: 48ch;
  }

  .thesis__lines {
    list-style: none;
    counter-reset: thesis;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .thesis__lines li {
    counter-increment: thesis;
    position: relative;
    padding-left: 2.5em;
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'wght' 340, 'SOFT' 40;
    font-size: var(--text-xl);
    line-height: 1.35;
    color: var(--color-ink);
  }

  .thesis__lines li::before {
    content: counter(thesis, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0.45em;
    font-family: var(--font-mono);
    font-size: 0.55em;
    color: var(--color-ink-faint);
    letter-spacing: 0.08em;
  }

  .thesis__accent {
    font-style: italic;
    font-variation-settings: 'opsz' 36, 'wght' 420, 'SOFT' 60;
  }
  .thesis__accent--i   { color: var(--color-act-i); }
  .thesis__accent--ii  { color: var(--color-act-ii); }
  .thesis__accent--iii { color: var(--color-act-iii); }

  /* Disclaimer */
  .hero__disclaimer {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    max-width: 58ch;
    padding: var(--space-5) var(--space-6);
    border-left: 2px solid var(--color-rule);
    background: color-mix(in srgb, var(--color-ground-tint) 40%, transparent);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: 1.6;
    font-style: italic;
  }

  .hero__disclaimer-marker {
    font-family: var(--font-mono);
    font-style: normal;
    color: var(--color-ink-faint);
    font-size: 1.2em;
    line-height: 1;
  }

  /* Living-document status */
  .hero__status {
    margin-top: var(--space-5);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
  }

  .hero__status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-act-iii);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-act-iii) 60%, transparent);
    animation: pulse 2.4s var(--ease-out) infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-act-iii) 50%, transparent);
      opacity: 1;
    }
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-act-iii) 0%, transparent);
      opacity: 0.7;
    }
  }

  .hero__status-label {
    color: var(--color-ink);
    font-variation-settings: 'wght' 520;
  }

  .hero__status-sep {
    color: var(--color-ink-faint);
  }

  .hero__status-note {
    text-transform: none;
    letter-spacing: 0.02em;
    color: var(--color-ink-muted);
    font-style: italic;
    font-family: var(--font-body);
    font-size: var(--text-sm);
  }

  @media (max-width: 36rem) {
    .hero__status {
      flex-wrap: wrap;
      gap: var(--space-1) var(--space-2);
    }
    .hero__status-sep { display: none; }
    .hero__status-note {
      width: 100%;
      margin-left: calc(8px + var(--space-2));
    }
  }

  /* ——— Acts ——— */
  .acts {
    padding: var(--space-20) var(--safe-right) var(--space-20) var(--safe-left);
    border-bottom: 1px solid var(--color-rule-soft);
  }

  .acts__inner {
    max-width: var(--page-max);
    margin: 0 auto;
  }

  .acts__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
    flex-wrap: wrap;
  }

  .acts__label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-muted);
  }

  .acts__label .glyph-stack {
    color: var(--color-ink-faint);
  }

  .acts__heading {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 72, 'wght' 330, 'SOFT' 40;
    font-size: var(--text-3xl);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    max-width: 16ch;
    text-align: right;
    text-wrap: balance;
  }

  @media (max-width: 48rem) {
    .acts__heading {
      text-align: left;
      font-size: var(--text-2xl);
      max-width: 20ch;
    }
  }

  .acts__grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--color-rule);
    border-left: 1px solid var(--color-rule);
  }

  @media (max-width: 62rem) {
    .acts__grid {
      grid-template-columns: 1fr;
      border-left: none;
    }
  }

  .act-card {
    position: relative;
    border-right: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    overflow: hidden;
  }

  @media (max-width: 62rem) {
    .act-card {
      border-left: 1px solid var(--color-rule);
    }
  }

  .act-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--acc, var(--color-ink)) 7%, transparent),
      transparent 55%);
    opacity: 0;
    transition: opacity var(--dur-med) var(--ease-out);
    pointer-events: none;
  }

  .act-card:hover::before {
    opacity: 1;
  }

  .act-card--i   { --acc: var(--color-act-i); }
  .act-card--ii  { --acc: var(--color-act-ii); }
  .act-card--iii { --acc: var(--color-act-iii); }

  .act-card__link {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
    gap: var(--space-6);
    padding: var(--space-8);
    text-decoration: none;
    color: inherit;
    min-height: 20rem;
    position: relative;
    z-index: 1;
  }

  .act-card__numeral {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 144, 'wght' 280, 'SOFT' 100;
    font-size: clamp(5rem, 10vw, 8rem);
    line-height: 0.85;
    color: var(--acc);
    opacity: 0.9;
    letter-spacing: -0.03em;
    transition: opacity var(--dur-med) var(--ease-out), transform var(--dur-slow) var(--ease-out);
  }

  .act-card:hover .act-card__numeral {
    opacity: 1;
    transform: translateY(-2px);
  }

  .act-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .act-card__title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .act-card__name {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'wght' 400, 'SOFT' 30;
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--acc);
  }

  .act-card__arrow {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 24, 'wght' 400, 'SOFT' 40;
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
    transition: transform var(--dur-med) var(--ease-out), color var(--dur-fast);
  }

  .act-card:hover .act-card__arrow {
    transform: translateX(6px);
    color: var(--acc);
  }

  .act-card__premise {
    font-family: var(--font-body);
    font-variation-settings: 'wght' 560;
    font-size: var(--text-base);
    color: var(--color-ink);
    line-height: 1.4;
  }

  .act-card__detail {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: 1.6;
  }

  /* ——— TOC section ——— */
  .toc-section {
    padding: var(--space-20) var(--safe-right) var(--space-16) var(--safe-left);
  }

  .toc-section__inner {
    max-width: var(--page-max);
    margin: 0 auto;
  }

  .toc-section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
