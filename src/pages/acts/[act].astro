---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const ACT_DATA = {
  'volo-ergo-sum': {
    roman: 'I',
    name: 'Volo Ergo Sum',
    tagline: 'I want, therefore I am.',
    premise: 'Before thought, there were feelings — the layer we share with animals. Before feelings, there was want: a bacterium tracking a chemical gradient, an organism leaning toward or away before anything like a mind.',
    color: 'var(--color-act-i)',
    cls: 'i',
  },
  'initd': {
    roman: 'II',
    name: 'InitD',
    tagline: 'The bootstrap process of mind.',
    premise: 'Finite beings cannot meet reality whole. The universe is fractal — infinite detail at every scale, zoom in or out — and chaotic, rewinding and fast-forwarding without bottom. To be finite is to be selectively deaf and dumb, carving a workable cut from an inexhaustible world.',
    color: 'var(--color-act-ii)',
    cls: 'ii',
  },
  'mmm': {
    roman: 'III',
    name: 'MMM',
    tagline: 'Measure. Model. Manifest.',
    premise: 'Measure, Model, Manifest. The most meta process we can observe — in a cell, a child, a civilisation. Dupoux, LeCun, and Malik (2026) propose a three-system architecture for autonomous intelligence — observation (A), active-behavior (B), and meta-control (M) — a structural echo of the same shape, showing up where agency itself gets defined.',
    color: 'var(--color-act-iii)',
    cls: 'iii',
  },
} as const;

export function getStaticPaths() {
  const ACT_DATA_KEYS = ['volo-ergo-sum', 'initd', 'mmm'] as const;
  return ACT_DATA_KEYS.map((act) => ({ params: { act } }));
}

const { act } = Astro.params as { act: keyof typeof ACT_DATA };
const actData = ACT_DATA[act];

const allChapters = await getCollection('chapters', ({ data }) => !data.draft);
const actChapters = allChapters
  .filter((c) => c.data.act === act)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={actData.name} description={actData.premise}>
  <SiteHeader />
  <main class={`ap ap--${actData.cls}`} style={`--acc: ${actData.color}`}>

    <!-- Watermark numeral — fixed to viewport, atmospheric -->
    <span class="ap__watermark" aria-hidden="true">{actData.roman}</span>

    <div class="ap__container">

      <!-- Hero -->
      <header class="ap__hero">
        <p class="ap__eyebrow">
          <span class="ap__eyebrow-stack" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
          Act {actData.roman} of III
        </p>

        <div class="ap__numeral-row">
          <span class="ap__numeral" aria-hidden="true">{actData.roman}</span>
          <div class="ap__title-block">
            <h1 class="ap__name">{actData.name}</h1>
            <p class="ap__tagline">{actData.tagline}</p>
          </div>
        </div>

        <p class="ap__premise">{actData.premise}</p>

        <div class="ap__rule" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
      </header>

      <!-- Chapters -->
      <section class="ap__chapters" aria-labelledby="chapters-heading">
        <header class="ap__chapters-header">
          <h2 class="ap__chapters-heading" id="chapters-heading">Chapters</h2>
          <span class="ap__chapters-count">{String(actChapters.length).padStart(2, '0')} in this act</span>
        </header>

        <ol class="chl">
          {actChapters.map((chapter) => (
            <li class="chl__item">
              <a href={`/chapters/${chapter.id}`} class="chl__link">
                <span class="chl__num">
                  {chapter.data.chapterNumber != null
                    ? String(chapter.data.chapterNumber).padStart(2, '0')
                    : '·'}
                </span>
                <span class="chl__body">
                  <span class="chl__title">{chapter.data.title}</span>
                  {chapter.data.subtitle && (
                    <span class="chl__subtitle">{chapter.data.subtitle}</span>
                  )}
                </span>
                <span class="chl__arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .ap {
    position: relative;
    padding: var(--space-16) var(--safe-right) var(--space-16) var(--safe-left);
    overflow: hidden;
  }

  .ap__container {
    max-width: var(--page-max);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* Watermark numeral fills the negative space */
  .ap__watermark {
    position: absolute;
    top: 22vh;
    right: -0.08em;
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 144, 'wght' 260, 'SOFT' 100;
    font-size: clamp(30rem, 60vw, 60rem);
    color: var(--acc);
    opacity: 0.045;
    line-height: 0.8;
    letter-spacing: -0.04em;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    white-space: nowrap;
  }

  @media (max-width: 48rem) {
    .ap__watermark {
      top: 48vh;
      font-size: clamp(18rem, 80vw, 40rem);
      opacity: 0.05;
      right: -0.12em;
    }
  }

  /* Hero */
  .ap__hero {
    max-width: 48rem;
    margin-bottom: var(--space-20);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .ap__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-muted);
  }

  .ap__eyebrow-stack {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
  }
  .ap__eyebrow-stack span {
    display: block;
    height: 1px;
    border-radius: 1px;
    background: var(--acc);
  }
  .ap__eyebrow-stack span:nth-child(1) { width: 18px; }
  .ap__eyebrow-stack span:nth-child(2) { width: 12px; opacity: 0.6; }
  .ap__eyebrow-stack span:nth-child(3) { width: 6px;  opacity: 0.3; }

  .ap__numeral-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-8);
    align-items: end;
    margin-top: var(--space-2);
  }

  .ap__numeral {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 144, 'wght' 280, 'SOFT' 80;
    font-size: clamp(6rem, 16vw, 11rem);
    line-height: 0.82;
    color: var(--acc);
    letter-spacing: -0.03em;
  }

  .ap__title-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-bottom: 0.3em;
  }

  .ap__name {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 72, 'wght' 360, 'SOFT' 40;
    font-size: var(--text-3xl);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  @media (min-width: 48rem) {
    .ap__name { font-size: var(--text-4xl); }
  }

  .ap__tagline {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 36, 'wght' 350, 'SOFT' 40;
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--acc);
    line-height: 1.2;
  }

  .ap__premise {
    font-family: var(--font-body);
    font-variation-settings: 'opsz' 14, 'wght' 440;
    font-size: var(--text-lg);
    color: var(--color-ink-soft);
    line-height: 1.55;
    max-width: 58ch;
    margin-top: var(--space-4);
    text-wrap: pretty;
  }

  @media (max-width: 48rem) {
    .ap__premise {
      font-size: var(--text-base);
      line-height: 1.6;
    }
  }

  /* Three-bar rule */
  .ap__rule {
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    margin-top: var(--space-4);
  }
  .ap__rule span {
    display: block;
    height: 2px;
    background: var(--acc);
    border-radius: 1px;
  }
  .ap__rule span:nth-child(1) { width: 52px; }
  .ap__rule span:nth-child(2) { width: 32px; opacity: 0.6; }
  .ap__rule span:nth-child(3) { width: 14px; opacity: 0.3; }

  /* Chapters */
  .ap__chapters-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-rule);
  }

  .ap__chapters-heading {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 48, 'wght' 340, 'SOFT' 40;
    font-size: var(--text-2xl);
    color: var(--color-ink);
    line-height: 1;
  }

  .ap__chapters-count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink-muted);
  }

  /* Chapter list */
  .chl {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .chl__item {
    border-bottom: 1px solid var(--color-rule-soft);
  }

  .chl__link {
    display: grid;
    grid-template-columns: 3.5ch 1fr auto;
    column-gap: var(--space-4);
    padding: var(--space-5) 0;
    text-decoration: none;
    align-items: center;
    transition: padding-left var(--dur-med) var(--ease-out);
    position: relative;
  }

  .chl__link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%) scaleX(0);
    transform-origin: left center;
    width: var(--space-3);
    height: 1px;
    background: var(--acc);
    transition: transform var(--dur-med) var(--ease-out);
  }

  .chl__link:hover {
    padding-left: var(--space-5);
  }

  .chl__link:hover::before {
    transform: translateY(-50%) scaleX(1);
  }

  .chl__num {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    letter-spacing: 0.08em;
    align-self: center;
  }

  .chl__body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .chl__title {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 30, 'wght' 370, 'SOFT' 30;
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-ink);
    line-height: 1.25;
    transition: color var(--dur-fast);
  }

  .chl__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-ink-muted);
    line-height: 1.4;
  }

  .chl__arrow {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 18, 'wght' 320, 'SOFT' 40;
    font-size: var(--text-lg);
    color: var(--color-ink-faint);
    transition: transform var(--dur-med) var(--ease-out), color var(--dur-fast);
    align-self: center;
  }

  .chl__link:hover .chl__title {
    color: var(--acc);
  }

  .chl__link:hover .chl__arrow {
    color: var(--acc);
    transform: translateX(6px);
  }

  @media (max-width: 48rem) {
    .ap {
      padding: var(--space-10) var(--safe-right) var(--space-10) var(--safe-left);
    }
    .ap__numeral-row {
      grid-template-columns: 1fr;
      gap: var(--space-3);
      align-items: start;
    }
    .ap__title-block { padding-bottom: 0; }
    .ap__hero {
      margin-bottom: var(--space-12);
    }
    .chl__link {
      grid-template-columns: 3ch 1fr auto;
      padding: var(--space-4) 0;
    }
    .chl__title {
      font-size: var(--text-lg);
    }
    .chl__link:hover {
      padding-left: var(--space-3);
    }
  }
</style>
