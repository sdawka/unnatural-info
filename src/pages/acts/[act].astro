---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const ACT_DATA = {
  'volo-ergo-sum': {
    roman: 'I',
    name: 'Volo Ergo Sum',
    premise: 'Before explicit thought, there is want. Before ideology, before metaphysics, before language: attraction, aversion, care, preference, will.',
    color: 'var(--color-act-i)',
  },
  'initd': {
    roman: 'II',
    name: 'InitD',
    premise: 'Finite beings do not meet reality whole. They carve it. The first process — initialization of all distinction.',
    color: 'var(--color-act-ii)',
  },
  'mmm': {
    roman: 'III',
    name: 'MMM',
    premise: 'Growth happens through a loop: Measure, Model, Manifest. This is the most general recipe the book offers.',
    color: 'var(--color-act-iii)',
  },
} as const;

export function getStaticPaths() {
  const ACT_DATA_KEYS = ['volo-ergo-sum', 'initd', 'mmm'] as const;
  return ACT_DATA_KEYS.map((act) => ({ params: { act } }));
}

const { act } = Astro.params as { act: keyof typeof ACT_DATA };
const actData = ACT_DATA[act];

const allChapters = await getCollection('chapters', ({ data }) => !data.draft);
const actChapters = allChapters
  .filter((c) => c.data.act === act)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={actData.name} description={actData.premise}>
  <SiteHeader />
  <main class="act-page">
    <div class="act-page__container">

      <header class="act-header" style={`--act-color: ${actData.color}`}>
        <span class="act-roman" aria-hidden="true">{actData.roman}</span>
        <div class="act-header__text">
          <p class="act-label">Act {actData.roman}</p>
          <h1 class="act-name">{actData.name}</h1>
          <p class="act-premise">{actData.premise}</p>
        </div>
      </header>

      <hr />

      <section class="act-chapters">
        <h2 class="act-chapters__heading">Chapters</h2>
        <ol class="chapter-list">
          {actChapters.map((chapter) => (
            <li class="chapter-list__item">
              <a href={`/chapters/${chapter.id}`} class="chapter-list__link">
                {chapter.data.chapterNumber && (
                  <span class="chapter-list__number">
                    {String(chapter.data.chapterNumber).padStart(2, '0')}
                  </span>
                )}
                <span class="chapter-list__title">{chapter.data.title}</span>
                {chapter.data.subtitle && (
                  <span class="chapter-list__subtitle">{chapter.data.subtitle}</span>
                )}
              </a>
            </li>
          ))}
        </ol>
      </section>

    </div>

    <!-- Watermark roman numeral -->
    <span class="act-watermark" aria-hidden="true" style={`--act-color: ${actData.color}`}>
      {actData.roman}
    </span>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .act-page {
    padding: var(--space-16) var(--space-6);
    position: relative;
    overflow: hidden;
  }

  .act-page__container {
    max-width: var(--page-max);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .act-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-8);
    align-items: start;
    margin-bottom: var(--space-12);
  }

  .act-roman {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 300;
    color: var(--act-color);
    line-height: 0.9;
    padding-top: 0.1em;
  }

  .act-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--act-color);
    margin-bottom: var(--space-2);
  }

  .act-name {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 300;
    color: var(--color-ink);
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }

  .act-premise {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-ink-muted);
    max-width: 55ch;
    line-height: 1.6;
  }

  .act-chapters {
    margin-top: var(--space-12);
  }

  .act-chapters__heading {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-6);
  }

  .chapter-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .chapter-list__link {
    display: grid;
    grid-template-columns: 3ch 1fr;
    grid-template-rows: auto auto;
    column-gap: var(--space-4);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-rule);
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .chapter-list__link:hover {
    border-color: var(--color-ink);
  }

  .chapter-list__number {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    grid-row: 1 / 3;
    align-self: center;
    padding-top: 0.15em;
  }

  .chapter-list__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--color-ink);
    line-height: 1.3;
  }

  .chapter-list__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-ink-muted);
    margin-top: var(--space-1);
  }

  .act-watermark {
    position: fixed;
    bottom: -0.2em;
    right: -0.05em;
    font-family: var(--font-display);
    font-size: 40vw;
    font-weight: 300;
    color: var(--act-color);
    opacity: 0.04;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  @media (max-width: 768px) {
    .act-header {
      grid-template-columns: 1fr;
    }

    .act-roman {
      font-size: var(--text-4xl);
    }

    .act-name {
      font-size: var(--text-3xl);
    }
  }
</style>
